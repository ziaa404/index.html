  box.style.cssText = [
    'position:absolute',
    'top:' + (20 + (_wbBoxes.length % 5) * 40) + 'px',
    'right:' + (20 + (_wbBoxes.length % 3) * 30) + 'px',
    'max-width:calc(100% - 48px)',
    'min-width:140px',
