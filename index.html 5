/* transition سلس على كل شيء */
/* Theme transitions - only on structural elements, not every card */
body, .sidebar, .topbar, #bottomNav, .modal, .modal-hdr {
  transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
}
.nav-btn, .bn-item, .btn-ghost, input, select, textarea {
  transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
}

/* ══════════════════════════════════════════════════
   NAV-CARDS GRID (العرض الشامل + لوحة التحكم)
══════════════════════════════════════════════════ */
.nav-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 16px;
  direction: rtl;
  margin-top: 20px;
}
.nav-card {
  background: var(--glass-bg-strong);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1.5px solid var(--border);
  border-radius: var(--r);
  padding: 20px 18px 16px;
  cursor: none;
  transition: transform 0.22s cubic-bezier(.4,0,.2,1),
              box-shadow 0.22s cubic-bezier(.4,0,.2,1),
              border-color 0.22s cubic-bezier(.4,0,.2,1);
  position: relative; overflow: hidden;
  display: flex; flex-direction: column; gap: 12px;
  box-shadow: var(--shadow-sm);
  animation: ncFadeIn 0.38s cubic-bezier(.4,0,.2,1) both;
}
.nav-card::before {
  content: '';
  position: absolute; top: 0; right: 0; left: 0; height: 3.5px;
  background: var(--nc-accent, linear-gradient(90deg, var(--sky), var(--plum)));
  border-radius: var(--r) var(--r) 0 0;
  opacity: 0.90;
}
.nav-card:hover {
  transform: translateY(-5px) scale(1.018);
  box-shadow: var(--shadow-lg);
  border-color: var(--border2);
}
@keyframes ncFadeIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.nav-card:nth-child(1)  { animation-delay:.04s }
.nav-card:nth-child(2)  { animation-delay:.08s }
.nav-card:nth-child(3)  { animation-delay:.12s }
.nav-card:nth-child(4)  { animation-delay:.16s }
.nav-card:nth-child(5)  { animation-delay:.20s }
.nav-card:nth-child(6)  { animation-delay:.24s }
.nav-card:nth-child(7)  { animation-delay:.28s }
.nav-card:nth-child(8)  { animation-delay:.32s }
.nav-card:nth-child(9)  { animation-delay:.36s }
.nav-card:nth-child(10) { animation-delay:.40s }
.nav-card:nth-child(11) { animation-delay:.44s }
.nav-card:nth-child(12) { animation-delay:.48s }

.nc-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
.nc-icon {
  width: 46px; height: 46px; border-radius: 13px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 22px;
  background: var(--nc-icon-bg, rgba(21,101,192,0.10));
  border: 1.5px solid var(--nc-icon-border, rgba(21,101,192,0.20));
  box-shadow: 0 4px 14px var(--nc-icon-shadow, rgba(21,101,192,0.14));
}
.nc-badge {
  padding: 3px 11px; border-radius: 99px; font-size: 0.68rem; font-weight: 900;
  background: var(--nc-badge-bg, rgba(21,101,192,0.10));
  color: var(--nc-badge-color, var(--sky));
  border: 1px solid var(--nc-badge-border, rgba(21,101,192,0.20));
  white-space: nowrap;
}
.nc-title { font-size: 1.02rem; font-weight: 800; color: var(--ink2); }
.nc-desc  { font-size: 0.82rem; color: var(--muted); line-height: 1.60; flex: 1; }
.nc-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 11px; border-top: 1px solid var(--border);
}
.nc-stat { font-size: 0.76rem; color: var(--muted); font-weight: 600; }
.nc-stat strong { color: var(--ink2); font-size: 1rem; font-weight: 900; display: block; margin-bottom: 1px; }
.nc-arrow {
  width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
  background: var(--c-accent-bg); border: 1.5px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; color: var(--sky); transition: all 0.20s;
}
.nav-card:hover .nc-arrow { background: var(--sky); color: white; border-color: var(--sky); }

/* Combined-view filter strip */
.cv-filter-strip {
  display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  margin-bottom: 22px; padding: 13px 16px;
  background: var(--glass-bg); border: 1px solid var(--glass-border);
  border-radius: var(--r-sm); box-shadow: var(--shadow-sm);
}
.cv-filter-btn {
  padding: 6px 15px; border-radius: 99px; border: 1.5px solid var(--border);
  background: transparent; font-family: 'Tajawal', sans-serif;
  font-size: 0.80rem; font-weight: 700; color: var(--muted); cursor: none;
  transition: all 0.18s;
}
.cv-filter-btn:hover { background: var(--surface); color: var(--ink2); border-color: var(--border2); }
.cv-filter-btn.active { background: var(--sky); color: white; border-color: var(--sky); box-shadow: 0 4px 14px rgba(21,101,192,0.28); }
.cv-filter-label { font-size: 0.78rem; font-weight: 800; color: var(--muted2); }
.cv-search {
  display: flex; align-items: center; gap: 7px;
  background: var(--glass-bg-strong); border: 1.5px solid var(--border);
  border-radius: 99px; padding: 6px 14px; margin-right: auto;
}
.cv-search input {
  border: none; background: transparent; font-family: 'Tajawal', sans-serif;
  font-size: 0.82rem; color: var(--ink); outline: none; width: 150px;
}
.cv-search input::placeholder { color: var(--muted2); }

/* Group headers inside combined view */
.cv-group { margin-bottom: 30px; }
.cv-group-title {
  font-size: 0.76rem; font-weight: 900; color: var(--muted2);
  letter-spacing: 1.4px; margin-bottom: 14px;
  display: flex; align-items: center; gap: 8px;
}
.cv-group-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

