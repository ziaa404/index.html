function gbMarkCorrect(ci){
  document.getElementById('gbe_ans').value = ci;
  [0,1,2,3].forEach(j=>{
    const inp = document.getElementById('gbe_c'+j);
    const lbl = document.getElementById('gbe_label_'+j);
