/* ── THEME TOGGLE (٤ أوضاع: فاتح / ليلي / دافئ / معلمات) ─── */
.dark-toggle {
  width:80px; height:26px;
  background:rgba(21,101,192,0.10);
  border:1.5px solid rgba(21,101,192,0.20);
  border-radius:99px;
  position:relative; cursor:none;
  transition:background 0.3s, border-color 0.3s;
  flex-shrink:0; padding:0;
}
.dark-toggle::after {
  content:'';
  position:absolute;
  top:3px; right:3px;
  width:18px; height:18px;
  border-radius:50%;
  background:white;
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1), background 0.3s;
  box-shadow:0 1px 4px rgba(0,0,0,0.25);
}
.dark-toggle::before {
  content:'☀️';
  position:absolute;
  top:3px; right:3px;
  width:18px; height:18px;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:11px; line-height:18px; text-align:center;
  z-index:1;
  pointer-events:none;
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
body.dark .dark-toggle {
  background:rgba(66,165,245,0.28);
  border-color:rgba(66,165,245,0.45);
}
body.dark .dark-toggle::after {
  transform:translateX(-19px);
  background:#1e3a5f;
}
body.dark .dark-toggle::before {
  content:'🌙';
  transform:translateX(-19px);
}
body.theme-rose .dark-toggle {
  background: rgba(194,98,154,0.14);
  border-color: rgba(194,98,154,0.32);
}
body.theme-rose .dark-toggle::after {
  transform: translateX(-57px);
  background: linear-gradient(135deg, #e8a0c8, #c2629a);
  box-shadow: 0 0 8px rgba(194,98,154,0.38);
}
body.theme-rose .dark-toggle::before {
  content: '🌸';
  transform: translateX(-57px);
}

