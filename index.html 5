/* ══════════════════════════════════════════════
   📱 FULL MOBILE SUPPORT
══════════════════════════════════════════════ */

/* Disable custom cursor on touch devices */
@media (hover: none) and (pointer: coarse) {
  * { cursor: auto !important; }
  #cursor, #cursor-ring, #bg-canvas { display: none !important; }
}

/* Bottom Navigation Bar — mobile only */
#bottomNav {
  display: none;
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 300;
  background: rgba(255,255,255,0.80);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid rgba(255,255,255,0.75);
  padding: 6px 4px;
  padding-bottom: calc(6px + env(safe-area-inset-bottom));
  box-shadow: 0 -4px 24px rgba(99,120,200,0.12);
  grid-template-columns: repeat(5, 1fr);
  align-items: center;
}
.bn-item {
  display: flex; flex-direction: column; align-items: center;
  gap: 3px; padding: 7px 4px; border-radius: 12px;
  border: none; background: none; color: var(--muted2);
  font-family: 'Tajawal', sans-serif; font-size: 0.60rem;
  font-weight: 800; cursor: pointer; transition: all 0.15s;
  position: relative; min-width: 0;
}
.bn-item .bn-icon { font-size: 20px; line-height: 1; }
.bn-item.active { color: var(--sky); }
.bn-item.active .bn-dot {
  position: absolute; top: 4px; width: 4px; height: 4px;
  border-radius: 50%; background: var(--sky);
}
.bn-item .bn-badge {
  position: absolute; top: 2px; right: 6px;
  background: var(--ember); color: white;
  font-size: 0.55rem; font-weight: 900;
  width: 14px; height: 14px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 1.5px solid var(--card);
}

/* More menu sheet */
#moreSheet {
  display: none; position: fixed; inset: 0; z-index: 500;
  background: rgba(13,27,42,0.35); backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
#moreSheet.open { display: block; }
#moreSheetContent {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,0.80);
  border-radius: 24px 24px 0 0;
  padding: 12px 16px calc(20px + env(safe-area-inset-bottom));
  max-height: 75vh; overflow-y: auto;
  animation: sheetUp 0.28s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes sheetUp { from{transform:translateY(100%);opacity:0} to{transform:none;opacity:1} }
.sheet-handle {
  width: 40px; height: 4px; border-radius: 99px;
  background: rgba(99,120,200,0.30); margin: 0 auto 16px;
}
.sheet-title { font-size: 0.80rem; font-weight: 900; color: var(--muted2);
  letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px; }
.sheet-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.sheet-item {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  padding: 14px 8px; border-radius: 14px; border: none;
  background: rgba(230,235,255,0.60); color: var(--ink); cursor: pointer;
  font-family: 'Tajawal', sans-serif; font-size: 0.70rem; font-weight: 800;
  transition: all 0.12s; text-align: center;
}
.sheet-item:hover, .sheet-item:active { background: rgba(210,220,255,0.85); transform: scale(0.96); }
.sheet-item .si-icon { font-size: 24px; }

/* Floating Action Button */
#fab {
  display: none; position: fixed; bottom: calc(76px + env(safe-area-inset-bottom));
  left: 16px; width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, var(--ink2), var(--sky));
  color: white; font-size: 24px; border: none; cursor: pointer;
  box-shadow: 0 6px 20px rgba(21,101,192,0.40); z-index: 299;
  align-items: center; justify-content: center;
  transition: transform 0.2s, box-shadow 0.2s;
}
#fab:active { transform: scale(0.92); }
#fab.show { display: flex; }

/* Add bottom padding to content on mobile so bottom nav doesn't cover */
@media (max-width: 960px) {
  #app { padding-bottom: 0; }
  #bg-canvas { opacity: 0.25 !important; pointer-events: none; }
  .content {
    padding-bottom: calc(80px + env(safe-area-inset-bottom)) !important;
  }
  #bottomNav { display: grid; }
  /* زر FAB يظهر فقط عند إضافة class show — لا نفرض display:flex هنا */

  /* Topbar mobile adjustments */
  .tb-save { display: none; }
  .tb-brand .tb-sub { display: none; }
  .tb-brand h2, .tb-title { font-size: 0.88rem; }
  .tb-username { display: none; }
  .tb-logout { display: none; }
  .dark-toggle { display: none; }

  .tb-notif, #sfxToggle, .tb-user {
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    touch-action: manipulation;
  }

  /* Page header stack on mobile */
  .ph { flex-direction: column; gap: 10px; }
  .ph-actions { width: 100%; flex-wrap: wrap; }
  .ph-actions .btn { flex: 1; justify-content: center; min-width: 100px; }

  /* KPI grid 2 col on mobile */
  .kpi-grid { grid-template-columns: 1fr 1fr; }

  /* Cards full width */
  .modal { border-radius: 20px 20px 0 0 !important; }
  .modal-bg { align-items: flex-end !important; padding: 0 !important; }

  /* Tables scrollable */
  .tbl-wrap { -webkit-overflow-scrolling: touch; }

  /* Forms full width */
  .form-row { flex-direction: column; }

  /* Charts smaller height */
  .chart-h-280 { height: 200px; }
  .chart-h-220 { height: 180px; }

  /* Seat map smaller */
  .seat-cell { min-height: 58px; }
  .seat-node { width: 44px; height: 44px; font-size: 18px; }

  /* Eval items compact */
  .eval-item { padding: 9px 10px; }
  .eval-btns { gap: 5px; }
  .ev-btn { padding: 5px 10px; font-size: 0.74rem; }

  /* Behavior grid single col */
  .beh-grid { grid-template-columns: 1fr; }

  /* Hide some columns in tables */
  .hide-mobile { display: none !important; }

  /* Quick eval bar bigger on mobile */
  .qe-bar { bottom: calc(80px + env(safe-area-inset-bottom)); width: 95vw; }

  /* Toast above bottom nav */
  .toast-wrap { bottom: calc(80px + env(safe-area-inset-bottom)); }

  /* PWA banner above bottom nav */
  #pwaInstallBanner { bottom: calc(80px + env(safe-area-inset-bottom)); right: 8px; left: 8px; }
}

/* Safe area for iPhone notch/home indicator */
@supports (padding: env(safe-area-inset-bottom)) {
  .topbar {
    padding-top: env(safe-area-inset-top);
  }
}

/* Landscape mobile */
@media (max-width: 960px) and (orientation: landscape) {
  .content { padding-bottom: calc(64px + env(safe-area-inset-bottom)) !important; }
  #bottomNav { padding-bottom: calc(4px + env(safe-area-inset-bottom)); }
  .chart-h-280 { height: 160px; }
}

