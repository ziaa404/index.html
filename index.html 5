/* ── SEAT MAP ─────────────────────────────── */
.seat-grid { display:grid; gap:10px; padding:20px; }
.seat-cell {
  background: var(--glass-bg);
  border: 2px solid var(--glass-border); border-radius: 14px;
  padding: 10px 8px; text-align: center; cursor: none; transition: all 0.18s;
  position: relative; min-height: 72px; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 4px;
}
.seat-cell:hover { transform:scale(1.04); box-shadow:var(--shadow); border-color:rgba(99,160,220,0.50); }
.seat-cell.empty { background: rgba(200,210,240,0.25); border-style:dashed; border-color:rgba(99,120,200,0.20); }
.seat-cell.present { border-color:var(--mint); background:rgba(16,185,129,0.08); }
.seat-cell.absent  { border-color:var(--ember); background:rgba(239,68,68,0.06); }
.seat-avatar {
  width:34px; height:34px; border-radius:50%; color:white;
  display:flex; align-items:center; justify-content:center;
  font-size:14px; font-weight:900;
}
.seat-name { font-size:0.70rem; font-weight:700; color:var(--ink); line-height:1.2; }
.seat-pct  { font-size:0.65rem; font-weight:800; }
.seat-toolbar { display:flex; gap:10px; align-items:center; margin-bottom:16px; flex-wrap:wrap; }
.seat-legend { display:flex; gap:12px; flex-wrap:wrap; font-size:0.78rem; font-weight:700; color:var(--muted); }
.seat-legend span { display:flex; align-items:center; gap:5px; }
.seat-legend .dot { width:10px; height:10px; border-radius:50%; }

/* ── BEHAVIOR TRACKER ────────────────────── */
.beh-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:14px; }
.beh-card {
  background: var(--glass-bg);
    border-radius:var(--r); border:1px solid var(--glass-border);
  padding:16px; transition:all 0.18s;
}
.beh-card:hover { transform:translateY(-2px); box-shadow:var(--shadow); }
.beh-header { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
.beh-stars { display:flex; gap:4px; }
.beh-star {
  font-size:20px; cursor:none; transition:transform 0.12s;
  filter:grayscale(1); opacity:0.35;
}
.beh-star.on { filter:none; opacity:1; transform:scale(1.15); }
.beh-tags { display:flex; flex-wrap:wrap; gap:5px; margin-top:10px; }
.beh-tag {
  padding:3px 10px; border-radius:99px; font-size:0.72rem; font-weight:800;
  cursor:none; border:1.5px solid transparent; transition:all 0.12s;
}
.beh-tag.pos { background:rgba(16,185,129,0.10); color:#059669; border-color:rgba(16,185,129,0.25); }
.beh-tag.pos.on { background:var(--mint); color:white; }
.beh-tag.neg { background:rgba(239,68,68,0.08); color:#dc2626; border-color:rgba(239,68,68,0.20); }
.beh-tag.neg.on { background:var(--ember); color:white; }
.beh-tag.neu { background:rgba(245,158,11,0.08); color:#b45309; border-color:rgba(245,158,11,0.20); }
.beh-tag.neu.on { background:var(--gold); color:white; }

/* ── GOALS / IEP ─────────────────────────── */
.goal-item {
  display:flex; align-items:flex-start; gap:10px; padding:12px 14px;
  border-radius:12px;
  background: rgba(230,236,255,0.65);
  border:1.5px solid rgba(99,120,200,0.18);
  margin-bottom:8px; transition:border 0.15s;
}
.goal-item:hover { border-color: rgba(99,120,200,0.35); }
.goal-check {
  width:20px; height:20px; border-radius:6px; border:2px solid rgba(99,120,200,0.30);
  flex-shrink:0; cursor:none; transition:all 0.15s; margin-top:2px;
  display:flex; align-items:center; justify-content:center; font-size:12px;
}
.goal-check.done { background:var(--mint); border-color:var(--mint); color:white; }
.goal-text { flex:1; font-size:0.88rem; color:var(--ink); }
.goal-text.done { text-decoration:line-through; color:var(--muted); }
.goal-meta { font-size:0.74rem; color:var(--muted2); margin-top:3px; }
.goal-deadline { font-size:0.74rem; }
.goal-deadline.overdue { color:var(--ember); font-weight:800; }
.goal-deadline.soon { color:var(--gold); font-weight:800; }

/* ── WEEKLY PLANNER ──────────────────────── */
.planner-grid {
  display:grid; grid-template-columns:repeat(5,1fr); gap:10px;
}
.planner-day {
  background: var(--glass-bg);
    border-radius:14px; border:1px solid var(--glass-border);
  overflow:hidden;
}
.planner-day-hdr {
  padding:10px 12px; background:linear-gradient(135deg,var(--ink2),var(--sky));
  color:white; font-weight:800; font-size:0.88rem; text-align:center;
}
.planner-day-hdr.today-hdr { background:linear-gradient(135deg,var(--gold),#e67e22); }
.planner-period {
  padding:8px 10px; border-bottom:1px solid rgba(99,120,200,0.12);
  font-size:0.80rem; cursor:none; transition:background 0.12s;
  min-height:52px;
}
.planner-period:hover { background: rgba(210,220,255,0.35); }
.planner-period:last-child { border-bottom:none; }
.pp-time { font-size:0.68rem; color:var(--muted2); font-weight:700; margin-bottom:3px; }
.pp-content { font-weight:700; color:var(--ink); }
.pp-empty { color:var(--muted2); font-style:italic; font-size:0.75rem; }

/* ── GRADE BOOK ──────────────────────────── */
.gb-table th { position:sticky; top:0; z-index:2; }
.gb-cell-input {
  width:48px; padding:5px 4px; border:1.5px solid rgba(99,120,200,0.25);
  border-radius:7px; text-align:center; font-family:'Tajawal',sans-serif;
  font-size:0.82rem; font-weight:800; outline:none;
  transition:border 0.15s; background: rgba(255,255,255,0.80);
}
.gb-cell-input:focus { border-color:var(--sky3); background:rgba(239,246,255,0.80); }
.gb-cell-input.high { color:#059669; }
.gb-cell-input.mid { color:#d97706; }
.gb-cell-input.low { color:#dc2626; }
.gb-avg { font-weight:900; font-size:0.88rem; }

/* ── MEETING LOG ─────────────────────────── */
.meeting-card {
  background: var(--glass-bg);
    border-radius: var(--r); border: 1px solid var(--glass-border);
  padding:16px 18px; margin-bottom:12px; transition:all 0.15s;
}
.meeting-card:hover { border-color: rgba(99,120,200,0.35); box-shadow: var(--shadow-sm); }
.meeting-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.meeting-title { font-weight:800; color:var(--ink2); font-size:0.95rem; }
.meeting-body { font-size:0.88rem; color:var(--ink); line-height:1.65; }
.meeting-footer { margin-top:10px; display:flex; gap:8px; flex-wrap:wrap; }

/* ── QUICK EVAL PANEL (inline swipe) ─────── */
.qe-bar {
  position:fixed; bottom:24px; right:50%; transform:translateX(50%);
  background: rgba(13,27,42,0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  color:white; border-radius:16px; padding:12px 20px;
  display:flex; align-items:center; gap:14px; box-shadow:var(--shadow-lg);
  border: 1px solid rgba(80,120,180,0.30);
  z-index:400; animation:slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);
  max-width:520px; width:90vw;
}
@keyframes slideUp { from{opacity:0;transform:translateX(50%) translateY(30px)} to{opacity:1;transform:translateX(50%) translateY(0)} }
.qe-bar.hidden { display:none; }
.qe-name { font-weight:800; font-size:0.92rem; flex:1; }
