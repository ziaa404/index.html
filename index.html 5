.cg-chair-btn.yes{background:rgba(16,185,129,0.20);border:1.5px solid rgba(16,185,129,0.40);color:var(--mint);}
.cg-chair-btn.no{background:rgba(245,158,11,0.18);border:1.5px solid rgba(245,158,11,0.35);color:var(--gold);}
.cg-chair-btn.pass{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.50);}

/* Race game */
.cg-race-question{font-size:2.2rem;font-weight:900;color:white;text-align:center;padding:28px;background:rgba(255,255,255,0.04);border-radius:16px;border:1px solid rgba(255,255,255,0.08);margin-bottom:16px;letter-spacing:-0.3px;}
.cg-race-scores{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;}
.cg-score-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:13px;padding:12px;text-align:center;transition:all 0.2s;cursor:none;}
.cg-score-card:hover{border-color:var(--mint);background:rgba(16,185,129,0.08);}
.cg-score-card.buzzing{animation:buzz 0.3s ease;border-color:var(--gold);background:rgba(245,158,11,0.12);}
@keyframes buzz{0%{transform:scale(1)}50%{transform:scale(1.08)}100%{transform:scale(1)}}
.cg-score-name{font-size:0.80rem;font-weight:700;color:rgba(255,255,255,0.80);margin-bottom:6px;}
.cg-score-pts{font-size:1.6rem;font-weight:900;color:var(--sky3);}

/* Word game */
.cg-word-display{font-size:4rem;font-weight:900;color:white;text-align:center;letter-spacing:10px;padding:32px;background:rgba(255,255,255,0.03);border-radius:16px;border:1px solid rgba(255,255,255,0.08);}
.cg-word-hint{font-size:1rem;color:rgba(255,255,255,0.45);text-align:center;margin-top:8px;}
.cg-word-reveal{font-size:1.5rem;font-weight:900;color:var(--mint);text-align:center;padding:16px;display:none;}
.cg-word-reveal.show{display:block;animation:popIn 0.3s cubic-bezier(0.34,1.56,0.64,1);}

/* Quiz progress dots */
.cg-progress-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0;transition:all 0.2s;}
.cg-dot-empty  {background:rgba(255,255,255,0.12);border:1.5px solid rgba(255,255,255,0.20);}
.cg-dot-current{background:rgba(66,165,245,0.30);border:2px solid var(--sky3);box-shadow:0 0 8px rgba(66,165,245,0.4);}
.cg-dot-correct{background:var(--mint);border:2px solid var(--mint);box-shadow:0 0 6px rgba(16,185,129,0.5);}
.cg-dot-wrong  {background:var(--ember);border:2px solid var(--ember);}

/* Shared game controls */
.cg-controls{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
.cg-score-bar{display:flex;gap:8px;padding:10px 14px;background:rgba(255,255,255,0.03);border-radius:12px;border:1px solid rgba(255,255,255,0.07);flex-wrap:wrap;}
.cg-score-item{display:flex;align-items:center;gap:6px;font-size:0.82rem;}
.cg-score-dot{width:8px;height:8px;border-radius:50%;}

/* In-game input */
.cg-live-input{background:rgba(255,255,255,0.07);border:1.5px solid rgba(255,255,255,0.15);border-radius:12px;padding:10px 16px;font-family:'Tajawal',sans-serif;font-size:1rem;color:white;outline:none;width:100%;text-align:right;}
