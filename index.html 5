/* ── وضع المعلمات — أناقة ناعمة (Soft Feminine Light) ────────── */
/*
  🎨 Color Palette:
  --bg-base:    #f5e6f0  (Blush Mist — very soft pink base)
  --orb1:       rgba(255,182,213,0.60)  (Soft Rose)
  --orb2:       rgba(216,191,255,0.50)  (Lavender Dream)
  --orb3:       rgba(255,218,185,0.45)  (Peach Glow)
  --orb4:       rgba(180,220,255,0.38)  (Baby Blue Whisper)
  --accent:     #c2629a  (Dusty Rose — readable, elegant)
  --accent2:    #e8a0c8  (Soft Pink)
  --ink:        #3d1f30  (Deep Plum — high contrast for text)
  --ink2:       #5a2d45  (Warm Plum)
  --muted:      #8a5a70  (Muted Mauve)
  --muted2:     #b48a9e  (Soft Mauve)
  --surface:    #fdf0f8  (Porcelain Pink)
  --card:       rgba(255,248,253,0.72)  (Pearl White with pink tint)
  --glass-bg:   rgba(255,242,250,0.68)
*/
body.theme-rose {
  --surface:#fdf0f8;
  --card:rgba(255,248,253,0.72);
  --border:rgba(194,98,154,0.18);
  --border2:rgba(194,98,154,0.32);
  --muted:#8a5a70;
  --muted2:#b48a9e;
  --ink:#3d1f30;
  --ink2:#5a2d45;
  --shadow-sm: 0 2px 18px rgba(194,98,154,0.10);
  --shadow: 0 8px 32px rgba(194,98,154,0.14);
  --shadow-lg: 0 20px 60px rgba(194,98,154,0.18);
  --shadow-xl: 0 32px 80px rgba(194,98,154,0.22);
  --glass-bg: rgba(255,242,250,0.68);
  --glass-bg-strong: rgba(255,248,253,0.90);
  --glass-border: rgba(255,220,240,0.85);
  --c-accent-bg: rgba(194,98,154,0.08);
  --accent: #c2629a;
  --accent2: #e8a0c8;
  --accent-glow: rgba(194,98,154,0.22);
  --accent-soft: rgba(194,98,154,0.09);
  --sky: #c2629a; --sky2: #a8507f; --sky3: #e8a0c8;
  --bg-base: #f5e6f0;
  --orb1: rgba(255,182,213,0.60);
  --orb2: rgba(216,191,255,0.50);
  --orb3: rgba(255,218,185,0.45);
  --orb4: rgba(180,220,255,0.38);
  background: var(--bg-base);
  background-image:
    radial-gradient(ellipse 80% 60% at 15% 10%, var(--orb1) 0%, transparent 58%),
    radial-gradient(ellipse 65% 55% at 85% 15%, var(--orb2) 0%, transparent 55%),
    radial-gradient(ellipse 70% 60% at 8%  82%, var(--orb3) 0%, transparent 58%),
    radial-gradient(ellipse 55% 55% at 88% 88%, var(--orb4) 0%, transparent 55%),
    radial-gradient(ellipse 90% 80% at 50% 50%, rgba(255,255,255,0.45) 0%, transparent 65%);
  background-attachment: fixed;
}

/* Topbar — soft glassmorphism matching other themes */
