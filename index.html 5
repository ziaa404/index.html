  } else if(type==='hot'){
    inner = `<div class="fg" style="margin:0"><label>السؤال</label>${inp('gbe_q', q.q)}</div>`;
  } else if(type==='race'){
    inner = `
      <div class="fg" style="margin:0"><label>السؤال</label>${inp('gbe_q', q.q)}</div>
