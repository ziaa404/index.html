/* ── SILVER / PEARL MODE (وضع القراءة الفضي) ─────────────────── */
body.theme-neu {
  /* ══ Claymorphism — Clay3D ══
     عناصر طينية ممتلئة، ظلال عميقة، ألوان حية
     aurora background + floating cards */
  --cl-bg1:    #0f0c29;
  --cl-bg2:    #302b63;
  --cl-bg3:    #24243e;
  --cl-card:   rgba(255,255,255,0.13);
  --cl-acc:    #a78bfa;
  --cl-acc2:   #60a5fa;
  --cl-green:  #34d399;
  --cl-gold:   #fbbf24;
  --cl-red:    #f87171;
  --cl-pink:   #f472b6;
  --cl-text:   #f0f4ff;
  --cl-muted:  rgba(200,210,255,0.60);
  --cl-muted2: rgba(180,190,240,0.40);
  --cl-border: rgba(255,255,255,0.18);
  --cl-border2:rgba(255,255,255,0.28);

  /* override system vars */
  --surface:   rgba(255,255,255,0.10);
  --card:      rgba(255,255,255,0.13);
  --border:    rgba(255,255,255,0.18);
  --border2:   rgba(255,255,255,0.28);
  --muted:     rgba(200,210,255,0.60);
  --muted2:    rgba(180,190,240,0.40);
  --ink:       #f0f4ff;
  --ink2:      #e2e8ff;
  --shadow-sm: 0 4px 20px rgba(0,0,0,0.25);
  --shadow:    0 8px 40px rgba(0,0,0,0.35);
  --shadow-lg: 0 20px 60px rgba(0,0,0,0.45);
  --shadow-xl: 0 32px 80px rgba(0,0,0,0.55);
  --glass-bg:        rgba(255,255,255,0.13);
  --glass-bg-strong: rgba(255,255,255,0.20);
  --glass-border:    rgba(255,255,255,0.22);
  --glass-blur:      blur(24px);
  --glass-blur-sm:   blur(14px);
  --c-accent-bg:     rgba(167,139,250,0.15);
  --accent:    #a78bfa;
  --accent2:   #60a5fa;
  --accent-glow: rgba(167,139,250,0.45);
  --accent-soft: rgba(167,139,250,0.15);
  --sky: #60a5fa; --sky2: #3b82f6; --sky3: #93c5fd;
  --r: 24px; --r-sm: 18px; --r-xs: 12px;

  background: var(--cl-bg1);
  background-image:
    radial-gradient(ellipse 90% 70% at 10% 5%,  rgba(139,92,246,0.55)  0%, transparent 55%),
    radial-gradient(ellipse 70% 65% at 90% 10%,  rgba(59,130,246,0.45)  0%, transparent 55%),
    radial-gradient(ellipse 75% 70% at 5%  90%,  rgba(16,185,129,0.35)  0%, transparent 58%),
    radial-gradient(ellipse 60% 60% at 92% 88%,  rgba(244,114,182,0.40) 0%, transparent 55%),
    radial-gradient(ellipse 100% 90% at 50% 50%, rgba(15,12,41,0.70)    0%, transparent 70%);
  background-attachment: fixed;
  color: var(--cl-text);
}

/* ══ Aurora background layer — animated ══ */
body.theme-neu::before {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 60% 50% at 20% 30%, rgba(139,92,246,0.30) 0%, transparent 60%),
    radial-gradient(ellipse 50% 45% at 80% 70%, rgba(59,130,246,0.25) 0%, transparent 60%),
    radial-gradient(ellipse 45% 40% at 60% 20%, rgba(16,185,129,0.20) 0%, transparent 60%);
  animation: clayAurora 12s ease-in-out infinite alternate;
}
@keyframes clayAurora {
  0%   { opacity: 0.7; transform: scale(1)    rotate(0deg); }
  50%  { opacity: 1.0; transform: scale(1.06) rotate(1deg); }
  100% { opacity: 0.8; transform: scale(0.97) rotate(-1deg); }
}

/* clay card mixin — raised 3D look */
/* ══ Topbar ══ */
body.theme-neu .topbar {
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px);
  border-bottom: 1px solid rgba(255,255,255,0.18);
  box-shadow: 0 4px 30px rgba(0,0,0,0.30), inset 0 1px 0 rgba(255,255,255,0.25);
  position: relative; z-index: 200;
}
body.theme-neu .topbar::before {
  background: linear-gradient(135deg, rgba(139,92,246,0.12) 0%, rgba(59,130,246,0.08) 50%, transparent 100%);
}
body.theme-neu .topbar::after {
  background: linear-gradient(90deg, #8b5cf6, #60a5fa, #34d399, #f472b6);
  height: 2px; opacity: 0.90;
  box-shadow: 0 0 16px rgba(139,92,246,0.60);
}
body.theme-neu .tb-title    { color: #f0f4ff; font-weight: 800; letter-spacing: -0.3px; }
body.theme-neu .tb-sub      { color: var(--cl-muted); }
body.theme-neu .tb-username { color: #f0f4ff; }
body.theme-neu .tb-class-btn {
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.20);
  color: #f0f4ff; border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.20), inset 0 1px 0 rgba(255,255,255,0.18);
  backdrop-filter: blur(10px);
}
body.theme-neu .tb-class-btn:hover {
  background: rgba(139,92,246,0.20);
  border-color: rgba(139,92,246,0.50);
  box-shadow: 0 4px 18px rgba(139,92,246,0.30);
}
body.theme-neu .tb-notif {
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.18);
  color: #f0f4ff; border-radius: 50%;
  box-shadow: 0 2px 12px rgba(0,0,0,0.20), inset 0 1px 0 rgba(255,255,255,0.15);
}
body.theme-neu .tb-notif:hover { background: rgba(139,92,246,0.22); box-shadow: 0 0 18px rgba(139,92,246,0.40); }
body.theme-neu .tb-user {
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 30px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.20);
  backdrop-filter: blur(10px);
}
body.theme-neu .tb-logout {
  background: rgba(248,113,113,0.15);
  border: 1px solid rgba(248,113,113,0.35);
  color: #fca5a5; border-radius: 10px;
  box-shadow: 0 2px 10px rgba(248,113,113,0.20);
}
body.theme-neu .tb-logout:hover { background: rgba(248,113,113,0.28); box-shadow: 0 4px 18px rgba(248,113,113,0.35); }
body.theme-neu .pulse-dot { background: #34d399; box-shadow: 0 0 10px rgba(52,211,153,0.80); }
body.theme-neu .tb-save { color: var(--cl-muted); }
