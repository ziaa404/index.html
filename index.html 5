.cg-choice.wrong{background:rgba(239,68,68,0.15);border-color:rgba(239,68,68,0.35);color:var(--ember);}
.cg-choice-label{display:inline-block;width:22px;height:22px;border-radius:50%;background:rgba(255,255,255,0.10);font-size:0.76rem;font-weight:900;line-height:22px;text-align:center;margin-left:8px;}
