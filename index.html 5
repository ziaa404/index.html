// ══════════════════════════════════════════════
// 📐 SIDEBAR RESIZE — سحب حافة السايدبار
// ══════════════════════════════════════════════
(function initSidebarResize(){
  const handle   = document.getElementById('sidebarResizeHandle');
  const sidebar  = document.getElementById('sidebar');
  if(!handle || !sidebar) return;

  const MIN_W          = 60;
  const MAX_W          = 480;
  const SNAP_COLLAPSED = 60;
  const SNAP_DEFAULT   = 252;

  // استرجع العرض المحفوظ
  const savedW = parseInt(localStorage.getItem('bs_sidebar_w'));
  if(savedW >= MIN_W && savedW <= MAX_W) applySidebarWidth(savedW);

  function applySidebarWidth(w){
    w = Math.max(MIN_W, Math.min(MAX_W, w));
    sidebar.style.width = w + 'px';
    if(w <= 80) sidebar.classList.add('sb-collapsed');
    else        sidebar.classList.remove('sb-collapsed');
    localStorage.setItem('bs_sidebar_w', w);
  }

  let startX, startW, dragging = false;

  handle.addEventListener('mousedown', e=>{
    e.preventDefault();
    dragging = true;
    startX = e.clientX;
    startW = sidebar.getBoundingClientRect().width;
    handle.classList.add('dragging');
    document.body.style.userSelect = 'none';
    document.body.style.cursor     = 'ew-resize';
  });

  document.addEventListener('mousemove', e=>{
    if(!dragging) return;
    // RTL: السايدبار على اليمين، السحب لليسار يوسّع
    applySidebarWidth(startW + (startX - e.clientX));
  });

  document.addEventListener('mouseup', ()=>{
    if(!dragging) return;
    dragging = false;
    handle.classList.remove('dragging');
    document.body.style.userSelect = '';
    document.body.style.cursor     = '';
    // Snap
    const w = sidebar.getBoundingClientRect().width;
    if(w < 120)      applySidebarWidth(SNAP_COLLAPSED);
    else if(w < 190) applySidebarWidth(SNAP_DEFAULT);
  });

  // Touch
  handle.addEventListener('touchstart', e=>{
    startX = e.touches[0].clientX;
    startW = sidebar.getBoundingClientRect().width;
    dragging = true;
    handle.classList.add('dragging');
  }, {passive:true});

  document.addEventListener('touchmove', e=>{
    if(!dragging) return;
    e.preventDefault();
    applySidebarWidth(startW + (startX - e.touches[0].clientX));
  }, {passive:false});

  document.addEventListener('touchend', ()=>{
    if(!dragging) return;
    dragging = false;
    handle.classList.remove('dragging');
    const w = sidebar.getBoundingClientRect().width;
    if(w < 120)      applySidebarWidth(SNAP_COLLAPSED);
    else if(w < 190) applySidebarWidth(SNAP_DEFAULT);
  });

  // Double-click: toggle مصغّر ↔ افتراضي
  handle.addEventListener('dblclick', ()=>{
    const w = sidebar.getBoundingClientRect().width;
    applySidebarWidth(w <= 80 ? SNAP_DEFAULT : SNAP_COLLAPSED);
  });
})();
</script>
