/* ── GOOGLE CLASSROOM ────────────────────────── */
.gc-card {
  background:linear-gradient(135deg,rgba(66,133,244,0.08),rgba(52,168,83,0.06));
  border:1.5px solid rgba(66,133,244,0.20); border-radius:var(--r);
  padding:20px 22px; margin-bottom:16px;
}
.gc-header { display:flex; align-items:center; gap:12px; margin-bottom:14px; }
.gc-logo { font-size:28px; }
.gc-title { font-weight:800; color:#1a73e8; font-size:1rem; }
.gc-sub { font-size:0.80rem; color:var(--muted); margin-top:2px; }
.gc-steps { display:flex; flex-direction:column; gap:10px; }
.gc-step {
  display:flex; align-items:flex-start; gap:10px;
  padding:10px 14px; background:white; border-radius:10px;
  border:1px solid rgba(66,133,244,0.15); font-size:0.86rem;
}
.gc-step-num {
  width:24px; height:24px; border-radius:50%;
  background:#1a73e8; color:white; font-size:0.72rem; font-weight:900;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.gc-import-result {
  background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px;
  padding:12px 16px; margin-top:12px; font-size:0.86rem; color:#166534;
  display:none;
}


/* ─�� STUDENT PHOTOS ──────────────────────────── */
.stu-photo {
  border-radius:50%; object-fit:cover; flex-shrink:0;
  border:2px solid white; box-shadow:0 2px 8px rgba(0,0,0,0.15);
}
.stu-photo-wrap {
  position:relative; display:inline-flex;
  align-items:center; justify-content:center; flex-shrink:0;
}
.stu-photo-edit {
  position:absolute; bottom:-2px; right:-2px;
  width:18px; height:18px; border-radius:50%;
  background:var(--sky); border:2px solid white;
  display:flex; align-items:center; justify-content:center;
  font-size:9px; cursor:none; opacity:0;
  transition:opacity 0.15s; color:white; font-weight:900;
}
.stu-photo-wrap:hover .stu-photo-edit { opacity:1; }

/* Photo upload modal */
.photo-upload-zone {
  border:2.5px dashed var(--border2); border-radius:var(--r);
  padding:28px; text-align:center; cursor:none;
  transition:all 0.2s; background:var(--surface);
}
.photo-upload-zone:hover,
.photo-upload-zone.drag-over {
  border-color:var(--sky3); background:rgba(66,165,245,0.05);
}
.photo-upload-zone .upload-icon { font-size:42px; margin-bottom:10px; }
.photo-upload-zone h4 { font-size:1rem; font-weight:800; color:var(--ink2); margin-bottom:5px; }
.photo-upload-zone p { font-size:0.82rem; color:var(--muted); }
.photo-preview-wrap {
  position:relative; width:110px; height:110px; margin:0 auto 16px;
}
.photo-preview-wrap img {
  width:110px; height:110px; border-radius:50%;
  object-fit:cover; border:3px solid var(--sky3);
  box-shadow:var(--shadow);
}
.photo-preview-wrap .rm-photo {
  position:absolute; top:-4px; right:-4px;
  width:24px; height:24px; background:var(--ember);
  border-radius:50%; border:2px solid white; color:white;
  font-size:12px; cursor:none; display:flex;
  align-items:center; justify-content:center; font-weight:900;
}
.photo-class-grid {
  display:grid; grid-template-columns:repeat(auto-fill,minmax(100px,1fr));
  gap:12px; padding:4px;
}
.photo-class-item {
  display:flex; flex-direction:column; align-items:center; gap:6px;
  padding:10px 6px; border-radius:12px; border:1.5px solid var(--border);
  background:var(--card); cursor:none; transition:all 0.15s;
}
.photo-class-item:hover { border-color:var(--sky3); box-shadow:var(--shadow-sm); }
.photo-class-item .pc-name { font-size:0.72rem; font-weight:800; color:var(--ink2); text-align:center; }


/* ══════════════════════════════════════════════
   🖥️ CLASSROOM MODE v2 — Projector Layout
══════════════════════════════════════════════ */
#classroomOverlay{position:fixed;inset:0;z-index:1000;background:#0a0f1e;display:none;flex-direction:column;font-family:'Tajawal',sans-serif;direction:rtl;overflow:hidden;}
#classroomOverlay.open{display:flex;}

/* Header */
.cm-header{display:flex;align-items:center;justify-content:space-between;padding:0 20px;background:rgba(255,255,255,0.04);border-bottom:1px solid rgba(255,255,255,0.07);flex-shrink:0;height:58px;min-height:58px;max-height:58px;overflow:hidden;}
.cm-logo-badge{width:36px;height:36px;border-radius:9px;background:rgba(66,165,245,0.18);border:1px solid rgba(66,165,245,0.30);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.cm-school{color:rgba(255,255,255,0.55);font-size:0.76rem;font-weight:700;}
.cm-skill-live{color:var(--sky3);font-size:0.84rem;font-weight:800;margin-top:1px;}
.cm-clock-wrap{text-align:center;min-width:90px;}
.cm-clock-time{font-size:1.1rem;font-weight:900;color:white;letter-spacing:2px;font-variant-numeric:tabular-nums;line-height:1;width:90px;display:inline-block;}
.cm-clock-date{font-size:0.70rem;color:rgba(255,255,255,0.35);font-weight:600;margin-top:1px;white-space:nowrap;}
.cm-view-tabs{display:flex;background:rgba(255,255,255,0.06);border-radius:10px;padding:3px;gap:3px;border:1px solid rgba(255,255,255,0.08);}
.cm-view-tab{padding:6px 16px;border-radius:8px;border:none;background:none;font-family:'Tajawal',sans-serif;font-size:0.82rem;font-weight:800;color:rgba(255,255,255,0.40);cursor:none;transition:all 0.14s;}
.cm-view-tab.active{background:rgba(66,165,245,0.18);color:var(--sky3);}
.cm-exit{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.55);padding:6px 13px;border-radius:8px;font-family:'Tajawal',sans-serif;font-size:0.80rem;font-weight:700;cursor:none;transition:all 0.14s;}
.cm-exit:hover{background:rgba(239,68,68,0.18);border-color:var(--ember);color:var(--ember);}

/* Views */
.cm-views{flex:1;position:relative;overflow:hidden;}
.cm-view{position:absolute;inset:0;display:none;padding:16px 20px;}
.cm-view.active{display:flex;flex-direction:column;}

/* ── BOARD VIEW ── */
.cm-board-grid{display:grid;grid-template-columns:200px 1fr 240px;gap:14px;height:100%;}
.cm-board-left{display:flex;flex-direction:column;gap:12px;}
.cm-board-center{display:flex;flex-direction:column;gap:12px;overflow:hidden;}
.cm-board-right{display:flex;flex-direction:column;gap:8px;overflow:hidden;}

/* Cards */
.cm-timer-card,.cm-attendance-card,.cm-progress-card,.cm-star-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:14px 16px;}
.cm-card-title{font-size:0.76rem;font-weight:800;color:rgba(255,255,255,0.38);letter-spacing:0.8px;text-transform:uppercase;margin-bottom:10px;}

/* Timer */
.cm-timer-card{display:flex;flex-direction:column;align-items:center;gap:10px;flex:1;}
.cm-timer-label{font-size:0.72rem;font-weight:800;color:rgba(255,255,255,0.35);letter-spacing:1px;text-transform:uppercase;}
.cm-timer-ring{position:relative;width:180px;height:180px;flex-shrink:0;}
.cm-timer-ring svg{transform:rotate(-90deg);}
.ring-bg{fill:none;stroke:rgba(255,255,255,0.07);stroke-width:10;}
.ring-prog{fill:none;stroke:var(--sky3);stroke-width:10;stroke-linecap:round;transition:stroke-dashoffset 1s linear;}
.ring-prog.warn{stroke:var(--gold);}
.ring-prog.urgent{stroke:var(--ember);}
.cm-timer-display{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.cm-timer-time{font-size:2.4rem;font-weight:900;color:white;letter-spacing:-1px;font-variant-numeric:tabular-nums;}
.cm-timer-time.warn{color:var(--gold);}
.cm-timer-time.urgent{color:var(--ember);animation:timerPulse 0.7s ease infinite alternate;}
@keyframes timerPulse{from{opacity:1}to{opacity:0.4}}
.cm-timer-controls{display:flex;gap:8px;width:100%;}
.cm-btn{padding:8px 16px;border-radius:9px;border:none;font-family:'Tajawal',sans-serif;font-size:0.84rem;font-weight:800;cursor:none;transition:all 0.13s;display:flex;align-items:center;gap:6px;}
.cm-btn-primary{background:var(--sky3);color:var(--ink);flex:1;justify-content:center;}
.cm-btn-primary:hover{background:#63c4f8;transform:scale(1.03);}
.cm-btn-ghost{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.65);border:1px solid rgba(255,255,255,0.10);}
.cm-btn-ghost:hover{background:rgba(255,255,255,0.13);}
.cm-mini-timers-row{display:flex;gap:5px;width:100%;}
.cm-mini-btn{flex:1;padding:7px 4px;border-radius:7px;border:1px solid rgba(255,255,255,0.10);background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.55);font-family:'Tajawal',sans-serif;font-size:0.76rem;font-weight:800;cursor:none;transition:all 0.12s;}
.cm-mini-btn:hover{background:rgba(66,165,245,0.15);border-color:rgba(66,165,245,0.30);color:var(--sky3);}
.cm-mini-btn.active{background:rgba(239,68,68,0.15);border-color:var(--ember);color:var(--ember);}

/* Attendance grid */
.cm-att-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(44px,1fr));gap:7px;margin-bottom:10px;}
.cm-att-card{border-radius:10px;padding:7px 4px;text-align:center;transition:transform 0.12s;cursor:none;}
.cm-att-card:hover{transform:scale(1.08);}
.cm-att-card.present{background:rgba(16,185,129,0.18);border:1px solid rgba(16,185,129,0.30);}
.cm-att-card.absent{background:rgba(239,68,68,0.18);border:1px solid rgba(239,68,68,0.30);}
.cm-att-card.unknown{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);}
.cm-att-avatar{width:28px;height:28px;border-radius:50%;margin:0 auto 4px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;}
.cm-att-card.present .cm-att-avatar{background:var(--mint);color:var(--ink);}
.cm-att-card.absent  .cm-att-avatar{background:var(--ember);color:white;}
.cm-att-card.unknown .cm-att-avatar{background:rgba(255,255,255,0.10);color:rgba(255,255,255,0.40);}
.cm-att-name{font-size:0.60rem;font-weight:700;color:rgba(255,255,255,0.55);line-height:1.2;}
.cm-att-summary{font-size:0.78rem;color:rgba(255,255,255,0.40);text-align:center;font-weight:700;}

/* Progress */
.cm-big-pct{font-size:3.5rem;font-weight:900;color:white;text-align:center;letter-spacing:-2px;margin:4px 0;}
.cm-pct-bar-wrap{height:10px;background:rgba(255,255,255,0.08);border-radius:99px;overflow:hidden;margin-bottom:8px;}
.cm-pct-bar{height:100%;background:linear-gradient(90deg,var(--sky),var(--mint));border-radius:99px;transition:width 1s ease;}
.cm-pct-legend{display:flex;align-items:center;gap:5px;font-size:0.72rem;color:rgba(255,255,255,0.35);font-weight:700;flex-wrap:wrap;}
.cm-legend-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.cm-legend-dot.green{background:var(--mint);}
.cm-legend-dot.gold{background:var(--gold);}
.cm-legend-dot.red{background:var(--ember);}

/* Star card */
.cm-star-card{text-align:center;background:linear-gradient(135deg,rgba(245,158,11,0.12),rgba(124,58,237,0.10));border-color:rgba(245,158,11,0.25);}
.cm-star-crown{font-size:2rem;animation:starFloat 2s ease-in-out infinite alternate;}
@keyframes starFloat{from{transform:translateY(0)}to{transform:translateY(-6px)}}
.cm-star-card-name{font-size:1.1rem;font-weight:900;color:white;margin:4px 0;}
.cm-star-card-sub{font-size:0.72rem;color:rgba(255,255,255,0.40);font-weight:700;}

/* Eval card inside classroom */
.cm-eval-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:14px 16px;flex:1;overflow:hidden;display:flex;flex-direction:column;}
.cm-eval-stu-btn{
  display:flex;align-items:center;gap:7px;padding:7px 9px;border-radius:9px;
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);
  cursor:none;transition:all 0.12s;position:relative;
}
.cm-eval-stu-btn:hover{background:rgba(255,255,255,0.10);}
.cm-eval-stu-name{font-size:0.74rem;font-weight:700;color:rgba(255,255,255,0.80);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
.cm-eval-stu-status{font-size:0.80rem;flex-shrink:0;}
.cm-eval-stu-btn.ev-mastered{background:rgba(16,185,129,0.12);border-color:rgba(16,185,129,0.25);}
.cm-eval-stu-btn.ev-not{background:rgba(239,68,68,0.12);border-color:rgba(239,68,68,0.25);}

/* Top list */
.cm-top-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);}
.cm-top-medal{font-size:1rem;width:22px;text-align:center;flex-shrink:0;}
.cm-top-name{flex:1;font-size:0.82rem;color:rgba(255,255,255,0.85);font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cm-top-pct{font-size:0.80rem;font-weight:900;}

/* ── WHEEL VIEW ── */
.cm-wheel-fullscreen{display:flex;gap:32px;height:100%;align-items:center;justify-content:center;}
.cm-wheel-left{display:flex;flex-direction:column;align-items:center;gap:16px;}
.cm-wheel-right{display:flex;flex-direction:column;gap:16px;min-width:280px;max-width:320px;height:100%;justify-content:center;}
.cm-wheel-title{font-size:1.6rem;font-weight:900;color:white;letter-spacing:-0.5px;}
.cm-wheel-subtitle{font-size:0.88rem;color:rgba(255,255,255,0.40);}
.cm-wheel-canvas-wrap{position:relative;width:380px;height:380px;}
#cmWheelCanvas{border-radius:50%;box-shadow:0 0 40px rgba(0,0,0,0.60);}
.cm-wheel-pointer{position:absolute;top:-16px;left:50%;transform:translateX(-50%);width:0;height:0;border-left:14px solid transparent;border-right:14px solid transparent;border-top:28px solid var(--gold);filter:drop-shadow(0 2px 8px rgba(245,158,11,0.7));}
.cm-spin-btn{padding:16px 40px;border-radius:99px;border:none;background:linear-gradient(135deg,var(--sky),var(--plum));color:white;font-family:'Tajawal',sans-serif;font-size:1.1rem;font-weight:900;cursor:none;transition:all 0.18s;box-shadow:0 8px 24px rgba(21,101,192,0.40);}
.cm-spin-btn:hover{transform:scale(1.04);box-shadow:0 12px 32px rgba(21,101,192,0.50);}
.cm-spin-btn:disabled{opacity:0.5;}
.cm-wheel-result-big{background:rgba(66,165,245,0.10);border:1px solid rgba(66,165,245,0.22);border-radius:18px;padding:24px 20px;text-align:center;min-height:140px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;}
.cm-wrb-emoji{font-size:3rem;}
.cm-wrb-text{font-size:1.5rem;font-weight:900;color:white;letter-spacing:-0.5px;}
.cm-wrb-sub{font-size:0.84rem;color:rgba(255,255,255,0.45);}
.cm-wheel-history-wrap{flex:1;overflow-y:auto;}
.cm-hist-item{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:8px;background:rgba(255,255,255,0.04);margin-bottom:5px;font-size:0.82rem;color:rgba(255,255,255,0.65);font-weight:600;}
.cm-hist-num{width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,0.08);font-size:0.68rem;font-weight:900;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.40);flex-shrink:0;}

/* ── HONOR VIEW ── */
.cm-honor-fullscreen{position:relative;display:flex;flex-direction:column;align-items:center;height:100%;padding:10px 20px;}
.cm-honor-header{text-align:center;margin-bottom:20px;}
.cm-honor-title{font-size:2rem;font-weight:900;color:white;letter-spacing:-0.5px;}
.cm-honor-date{font-size:0.82rem;color:rgba(255,255,255,0.35);margin-top:4px;}
.cm-honor-podium{display:flex;align-items:flex-end;justify-content:center;gap:12px;margin-bottom:20px;}
.cm-podium-item{display:flex;flex-direction:column;align-items:center;gap:8px;}
.cm-podium-avatar{border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:900;color:white;flex-shrink:0;border:3px solid rgba(255,255,255,0.20);}
.cm-podium-name{font-weight:800;color:white;text-align:center;line-height:1.2;}
.cm-podium-pct{font-weight:900;text-align:center;}
.cm-podium-base{border-radius:12px 12px 0 0;width:100%;display:flex;align-items:flex-end;justify-content:center;padding-bottom:8px;}
.cm-podium-rank{font-size:0.72rem;color:rgba(255,255,255,0.50);font-weight:800;}
/* 1st place */
.cm-podium-item.first .cm-podium-avatar{width:80px;height:80px;font-size:32px;}
.cm-podium-item.first .cm-podium-name{font-size:1rem;}
.cm-podium-item.first .cm-podium-pct{font-size:1.1rem;color:var(--gold);}
.cm-podium-item.first .cm-podium-base{height:80px;background:linear-gradient(180deg,rgba(245,158,11,0.25),rgba(245,158,11,0.08));border:1px solid rgba(245,158,11,0.25);min-width:140px;}
/* 2nd */
.cm-podium-item.second .cm-podium-avatar{width:64px;height:64px;font-size:26px;}
.cm-podium-item.second .cm-podium-name{font-size:0.88rem;}
.cm-podium-item.second .cm-podium-pct{font-size:0.92rem;color:rgba(255,255,255,0.60);}
.cm-podium-item.second .cm-podium-base{height:60px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.10);min-width:120px;}
/* 3rd */
.cm-podium-item.third .cm-podium-avatar{width:56px;height:56px;font-size:22px;}
.cm-podium-item.third .cm-podium-name{font-size:0.82rem;}
.cm-podium-item.third .cm-podium-pct{font-size:0.84rem;color:rgba(255,255,255,0.50);}
.cm-podium-item.third .cm-podium-base{height:44px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);min-width:110px;}
/* Rest */
.cm-honor-rest{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;max-width:900px;}
.cm-rest-chip{display:flex;align-items:center;gap:7px;padding:7px 13px;border-radius:99px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);font-size:0.82rem;color:rgba(255,255,255,0.65);font-weight:700;}

/* Status bar */
.cm-status-bar{display:flex;align-items:center;justify-content:space-between;padding:7px 20px;background:rgba(0,0,0,0.30);border-top:1px solid rgba(255,255,255,0.05);flex-shrink:0;}
.cm-status-dot{width:7px;height:7px;border-radius:50%;background:var(--mint);animation:pulse 2s infinite;}
.cm-status-text{font-size:0.76rem;color:rgba(255,255,255,0.40);font-weight:700;}
.cm-noise-mini{display:flex;align-items:center;gap:7px;}
.cm-noise-bar-h{width:60px;height:6px;background:rgba(255,255,255,0.08);border-radius:99px;overflow:hidden;}
.cm-noise-fill-h{height:100%;background:var(--mint);border-radius:99px;transition:width 0.18s ease;}

/* Noise alert */
#cmNoiseAlert{position:fixed;inset:0;z-index:1100;background:rgba(239,68,68,0.20);pointer-events:none;display:none;align-items:center;justify-content:center;}
#cmNoiseAlert.show{display:flex;animation:noiseFlash 0.5s ease;}

/* ══ GAMES CSS ═════════════════════════════════════════════ */
.cm-games-fullscreen{display:flex;gap:0;height:100%;}
.cm-games-sidebar{width:200px;flex-shrink:0;display:flex;flex-direction:column;gap:10px;padding:4px 0 12px;border-left:1px solid rgba(255,255,255,0.07);overflow-y:auto;}
.cm-games-title{font-size:0.80rem;font-weight:900;color:rgba(255,255,255,0.40);letter-spacing:1px;text-transform:uppercase;padding:0 8px 8px;border-bottom:1px solid rgba(255,255,255,0.07);}
.cm-games-list{display:flex;flex-direction:column;gap:7px;}
.cm-game-btn{display:flex;flex-direction:column;align-items:flex-start;gap:1px;padding:9px 11px;border-radius:12px;border:1px solid rgba(255,255,255,0.07);background:rgba(255,255,255,0.03);cursor:none;transition:all 0.13s;text-align:right;font-family:'Tajawal',sans-serif;}
.cm-game-btn:hover{background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.14);}
.cm-game-btn.active{background:rgba(66,165,245,0.12);border-color:rgba(66,165,245,0.28);}
.cg-icon{font-size:1.2rem;}
.cg-name{font-size:0.80rem;font-weight:800;color:rgba(255,255,255,0.85);}
.cg-sub{font-size:0.66rem;color:rgba(255,255,255,0.35);font-weight:600;}
