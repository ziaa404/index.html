/* Result overlay inside game */
.cg-result{text-align:center;padding:32px;background:linear-gradient(135deg,rgba(16,185,129,0.10),rgba(66,165,245,0.08));border-radius:18px;border:1px solid rgba(16,185,129,0.20);}
.cg-result-emoji{font-size:3.5rem;margin-bottom:8px;}
.cg-result-title{font-size:1.5rem;font-weight:900;color:white;margin-bottom:4px;}
.cg-result-sub{font-size:0.88rem;color:rgba(255,255,255,0.45);}

/* ══ SLIDES VIEW ════════════════════════════════════════════ */
.cm-slides-layout{display:flex;gap:0;height:100%;}
